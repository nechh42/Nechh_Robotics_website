{
    "version": 2,
    "crons": [
        {
            "path": "/api/cron/daily-check",
            "schedule": "0 9 * * *"
        }
    ],
    "routes": [
        {
            "src": "/api/nechh-data",
            "dest": "/api/nechh-data.js"
        },
        {
            "src": "/api/admin/subscribers",
            "dest": "/api/admin/subscribers.js"
        },
        {
            "src": "/api/register",
            "dest": "/api/register.js"
        },
        {
            "src": "/api/email/send",
            "dest": "/api/email/send.js"
        },
        {
            "src": "/api/cron/daily-check",
            "dest": "/api/cron/daily-check.js"
        },
        {
            "src": "/trades.json",
            "dest": "/trades.json",
            "headers": {
                "Cache-Control": "no-store, max-age=0"
            }
        }
    ]
}